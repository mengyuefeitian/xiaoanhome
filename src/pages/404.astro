---
import Base from '../layouts/Base.astro';
---
<Base
  title="404 · 页面未找到"
  description="你访问的页面不存在。"
  lang="zh"
>
<section class="hero sec-dark" style="min-height:70vh;display:flex;align-items:center;justify-content:center;text-align:center">
  <div class="wrap">
    <p class="eyebrow" style="font-size:72px;font-weight:700;letter-spacing:-0.02em;background:none;-webkit-text-fill-color:inherit;color:#86868b;margin-bottom:24px">404</p>
    <h1 style="font-size:clamp(32px,5vw,56px);margin-bottom:16px">页面未找到</h1>
    <p class="lead" style="max-width:480px;margin:0 auto 40px">你访问的页面不存在，可能已被移除或链接有误。</p>
    <a class="btn btn-primary" href="/">回到首页</a>
  </div>
</section>
</Base>
