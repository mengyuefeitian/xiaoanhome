---
import Base from '../../layouts/Base.astro';
import { getT } from '../../i18n/utils';

const t = getT('zh');
const app = t.apps.lumibox;
---
<Base
  title="拾光匣 LumiBox · NAS 相册同步与浏览"
  description={app.tagline}
  lang="zh"
>

<!-- Hero (dark) -->
<section class="hero sec-dark" id="top">
  <div class="wrap">
    <p class="eyebrow">拾光匣</p>
    <h1>你的照片<br>始终在你掌控之间</h1>
    <p class="lead">{app.desc}</p>
    <p class="hero-sub"><img src="/images/icon-harmonyos.svg" class="pi" alt="" width="22" height="22" style="width:22px;height:22px">HarmonyOS App</p>
    <div class="hero-device" style="padding-bottom:60px">
      <div class="app-showcase" style="transform:translateY(40px)">
        <img src="/images/lumibox-icon.png" alt="拾光匣图标" class="showcase-icon" width="140" height="140" />
      </div>
    </div>
  </div>
</section>

<!-- Feature spotlights (dark) -->
<section class="sec-dark" id="features">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">为什么选择拾光匣</p>
      <h2>备份、浏览、一气呵成</h2>
      <p class="lead">将群晖 NAS 与华为手机相册无缝打通，照片数据始终在你自己手中。</p>
    </div>

    <div class="spot reveal">
      <div class="spot-text">
        <h2>增量同步<br>省时省流量</h2>
        <p class="lead">Delta 同步策略，仅传输 NAS 上没有的文件，断点续传，无需重头开始，真正节省你的时间与流量。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/lumibox-icon.png" alt="拾光匣" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot rev reveal">
      <div class="spot-text">
        <h2>相册时间线<br>完整呈现</h2>
        <p class="lead">按年、月、日浏览 NAS 中的全部照片，目录结构完整保留，一如手机相册般熟悉自然。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/lumibox-icon.png" alt="拾光匣" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot reveal">
      <div class="spot-text">
        <h2>HDR Vivid 预览<br>华为专属体验</h2>
        <p class="lead">在支持的华为设备上以 HDR Vivid 渲染意图播放媒体，完整支持华为动态照片的上传、同步与播放预览，色彩更真实。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/lumibox-icon.png" alt="拾光匣" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot rev reveal">
      <div class="spot-text">
        <h2>本地数据<br>完全掌控</h2>
        <p class="lead">照片直连你的群晖 NAS，绝不经过第三方云服务。可视化缓存管理，一键清理，存储自由掌控。</p>
      </div>
      <div class="spot-visual">
        <div class="privacy-gfx">📦</div>
      </div>
    </div>
  </div>
</section>

<!-- Feature grid (light) -->
<section class="sec-light">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">更多功能</p>
      <h2>每个细节都用心</h2>
    </div>
    <div class="grid">
      {app.features.map(f => (
        <div class="cell reveal">
          <div class="cell-ico">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<!-- Platform (darker) -->
<section class="sec-darker" id="platforms">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">平台</p>
      <h2>为华为而生</h2>
    </div>
    <div class="plats" style="grid-template-columns:1fr">
      <div class="plat reveal" style="max-width:560px;margin:0 auto">
        <span class="plat-tag">HarmonyOS</span>
        <h3>鸿蒙原生 App</h3>
        <ul>
          <li>ArkTS 原生开发，适配鸿蒙设计规范</li>
          <li>HDR Vivid 渲染，动态照片完整支持</li>
          <li>群晖 Synology NAS WebDAV 直连</li>
          <li>断点续传，增量同步</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<!-- Download (light) -->
<section class="sec-light get" id="get">
  <div class="wrap">
    <div class="reveal">
      <p class="eyebrow">立即获取</p>
      <h2>下载拾光匣</h2>
      <p class="lead">华为 AppGallery 免费下载。</p>
    </div>
    <div class="get-cards get-cards-2">
      <div class="get-card reveal">
        <img src="/images/icon-appgallery.svg" alt="" width="80" height="80" loading="lazy">
        <h3>华为应用市场</h3>
        <p>在 HarmonyOS 设备上搜索「拾光匣」或点击下方链接。</p>
        <a class="btn btn-primary" href="https://appgallery.huawei.com/" target="_blank" rel="noopener">前往应用市场</a>
      </div>
      <div class="get-card reveal">
        <div class="store-ph">🔒</div>
        <h3>隐私承诺</h3>
        <p>照片数据直连你的 NAS，不经过任何第三方服务器。</p>
        <a class="btn btn-light" style="border:1px solid rgba(0,0,0,.1)" href="/lumibox/privacy-policy">查看隐私政策</a>
      </div>
    </div>
  </div>
</section>

<div class="legal-links">
  <a href="/lumibox/privacy-policy">隐私政策</a>
  {' · '}
  <a href="/lumibox/user-agreement">用户协议</a>
</div>

<script>
(function(){
  var els = document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('in')});return;}
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('in'); io.unobserve(en.target); } });
  },{threshold:.15});
  els.forEach(function(e){io.observe(e)});
})();
</script>
</Base>
