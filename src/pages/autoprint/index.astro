---
import Base from '../../layouts/Base.astro';
import { getT } from '../../i18n/utils';

const t = getT('zh');
const app = t.apps.autoprint;
---
<Base
  title="自动打印 AutoPrint · macOS 文件夹监控自动打印"
  description={app.tagline}
  lang="zh"
>

<section class="hero sec-dark" id="top">
  <div class="wrap">
    <p class="eyebrow">自动打印</p>
    <h1>文件放进去<br>自动发给打印机</h1>
    <p class="lead">{app.desc}</p>
    <p class="hero-sub"><img src="/images/icon-macos.svg" class="pi" alt="" width="17" height="17">macOS 桌面应用</p>
    <div class="hero-device" style="padding-bottom:60px">
      <div class="app-showcase" style="transform:translateY(40px)">
        <img src="/images/autoprint-icon.png" alt="自动打印图标" class="showcase-icon" width="140" height="140" />
      </div>
    </div>
  </div>
</section>

<section class="sec-dark" id="features">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">为什么选择自动打印</p>
      <h2>配置一次，持续自动</h2>
      <p class="lead">将文件放入指定文件夹，应用自动扫描并发送到打印机，无需手动操作。</p>
    </div>

    <div class="spot reveal">
      <div class="spot-text">
        <h2>监控文件夹<br>自动触发打印</h2>
        <p class="lead">指定一个或多个本地文件夹作为监控目录，新文件出现自动触发打印任务，无需打开每个文件手动打印。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/autoprint-icon.png" alt="自动打印" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot rev reveal">
      <div class="spot-text">
        <h2>灵活选择打印机<br>多场景适配</h2>
        <p class="lead">列出系统全部可用打印机，为不同文件夹配置不同打印机，灵活适配办公室、教室、家庭等多种场景。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/autoprint-icon.png" alt="自动打印" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot reveal">
      <div class="spot-text">
        <h2>Office 文档转换<br>多格式支持</h2>
        <p class="lead">支持 PDF、图片及 Office 文档，可选 LibreOffice Headless、Microsoft Word 或 Pages 进行文档转换后打印。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/autoprint-icon.png" alt="自动打印" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot rev reveal">
      <div class="spot-text">
        <h2>打印记录<br>全程可查</h2>
        <p class="lead">记录每次打印的文件名和完成时间，便于核查和追溯历史打印任务，小型办公室也能有完整的打印日志。</p>
      </div>
      <div class="spot-visual">
        <div class="privacy-gfx">📜</div>
      </div>
    </div>
  </div>
</section>

<section class="sec-light">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">全部功能</p>
      <h2>小型办公室的打印利器</h2>
    </div>
    <div class="grid">
      {app.features.map(f => (
        <div class="cell reveal">
          <div class="cell-ico">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="sec-darker" id="platforms">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">平台</p>
      <h2>专为 macOS 打造</h2>
    </div>
    <div class="plats" style="grid-template-columns:1fr">
      <div class="plat reveal" style="max-width:560px;margin:0 auto">
        <span class="plat-tag">macOS</span>
        <h3>macOS 桌面应用</h3>
        <ul>
          <li>监控本地文件夹，自动触发打印</li>
          <li>支持 PDF、图片和 Office 文档</li>
          <li>可选文档转换引擎</li>
          <li>完整打印日志记录</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="sec-light get" id="get">
  <div class="wrap">
    <div class="reveal">
      <p class="eyebrow">立即获取</p>
      <h2>下载自动打印</h2>
      <p class="lead">GitHub 免费开源。</p>
    </div>
    <div class="get-cards" style="grid-template-columns:1fr;max-width:320px;margin-left:auto;margin-right:auto">
      <div class="get-card reveal">
        <div class="store-ph">🐙</div>
        <h3>GitHub</h3>
        <p>在 GitHub 查看源码或下载最新版本，开源免费。</p>
        <a class="btn btn-primary" href={app.downloadUrl} target="_blank" rel="noopener">{app.downloadLabel}</a>
      </div>
    </div>
  </div>
</section>

</Base>
