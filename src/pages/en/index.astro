---
import Base from '../../layouts/Base.astro';
import { getT } from '../../i18n/utils';

const t = getT('en');
const { apps } = t;

const products = [
  { app: apps.arcanekey,      href: '/en/arcanekey',        icon: '/images/arcanekey-icon.png',       iconAlt: 'ArcaneKey icon' },
  { app: apps.winterFortress, href: '/en/winter-fortress',  icon: '/images/winter-fortress-logo.svg', iconAlt: 'Winter Fortress Activity icon' },
  { app: apps.lumibox,        href: '/en/lumibox',          icon: '/images/lumibox-icon.png',         iconAlt: 'LumiBox icon' },
  { app: apps.autovolume,     href: '/en/autovolume',       icon: '/images/autovolume-icon.png',      iconAlt: 'AutoVolume icon' },
  { app: apps.autoprint,      href: '/en/autoprint',        icon: '/images/autoprint-icon.png',       iconAlt: 'AutoPrint icon' },
];
---
<Base
  title="XiaoAn Home · XiaoAn Studio"
  description="XiaoAn Studio independent developer portfolio — HarmonyOS, macOS & WeChat Mini Program apps."
  lang="en"
>
  <!-- Dark hero -->
  <section class="home-hero sec-dark">
    <div class="wrap">
      <p class="eyebrow">XiaoAn Studio · Independent Developer</p>
      <h1>{t.home.heroTitle}</h1>
      <p class="lead">{t.home.appsSubtitle}</p>
      <div class="home-hero-apps">
        {products.map(p => (
          <a href={p.href} class="home-hero-app">
            <img src={p.icon} alt={p.iconAlt} width="72" height="72" loading="eager" />
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- Product spots — alternating left/right -->
  <div class="home-spots">
    {products.map((p, i) => (
      <div class="wrap">
        <div class={`home-spot reveal${i % 2 === 1 ? ' rev' : ''}`}>
          <div class="home-spot-visual">
            <div class="home-spot-icon">
              <img src={p.icon} alt={p.iconAlt} width="110" height="110" loading={i === 0 ? 'eager' : 'lazy'} />
            </div>
          </div>
          <div class="home-spot-text">
            <p class="platform-tag">{p.app.platform.join(' · ')}</p>
            <h2>{p.app.nameEn}</h2>
            <p class="lead">{p.app.tagline}</p>
            <a href={p.href} class="tile-cta">Learn More ›</a>
          </div>
        </div>
      </div>
    ))}
  </div>

</Base>
