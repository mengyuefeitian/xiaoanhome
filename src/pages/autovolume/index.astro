---
import Base from '../../layouts/Base.astro';
import { getT } from '../../i18n/utils';

const t = getT('zh');
const app = t.apps.autovolume;
---
<Base
  title="智卷 AutoVolume · macOS 网络卷自动挂载"
  description={app.tagline}
  lang="zh"
>

<section class="hero sec-dark" id="top">
  <div class="wrap">
    <p class="eyebrow">智卷</p>
    <h1>设置一次<br>再也不用管</h1>
    <p class="lead">{app.desc}</p>
    <p class="hero-sub"><img src="/images/icon-macos.svg" class="pi" alt="" width="17" height="17">macOS 桌面应用</p>
    <div class="hero-device" style="padding-bottom:60px">
      <div class="app-showcase" style="transform:translateY(40px)">
        <img src="/images/autovolume-icon.png" alt="智卷图标" class="showcase-icon" width="140" height="140" />
      </div>
    </div>
  </div>
</section>

<section class="sec-dark" id="features">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">为什么选择智卷</p>
      <h2>静默运行，断线自愈</h2>
      <p class="lead">网络恢复即自动重连，彻底告别手动挂载烦恼。</p>
    </div>

    <div class="spot reveal">
      <div class="spot-text">
        <h2>四种协议<br>全面覆盖</h2>
        <p class="lead">支持 SMB、WebDAV、AFP、NFS 四种网络文件协议，覆盖主流 NAS、路由器外接硬盘、公司文件服务器与 WebDAV 云盘。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/autovolume-icon.png" alt="智卷" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot rev reveal">
      <div class="spot-text">
        <h2>自动重连<br>静默运行</h2>
        <p class="lead">网络中断后自动检测服务器恢复，静默重新挂载，无需手动打开 Finder，也不会弹出打扰通知。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/autovolume-icon.png" alt="智卷" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot reveal">
      <div class="spot-text">
        <h2>子目录挂载<br>精准定位</h2>
        <p class="lead">支持挂载服务器内部子目录，例如 smb://nas.local/share/tools，精准挂载你需要的路径，而非整个共享。</p>
      </div>
      <div class="spot-visual">
        <div class="app-showcase">
          <img src="/images/autovolume-icon.png" alt="智卷" class="showcase-icon" width="140" height="140" loading="lazy" />
        </div>
      </div>
    </div>

    <div class="spot rev reveal">
      <div class="spot-text">
        <h2>本地加密存储<br>不依赖钥匙串</h2>
        <p class="lead">密码保存在本地加密文件，不依赖 macOS 钥匙串，与各类 VPN 和网络环境兼容性更好，迁移更简单。</p>
      </div>
      <div class="spot-visual">
        <div class="privacy-gfx">🔒</div>
      </div>
    </div>
  </div>
</section>

<section class="sec-light">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">全部功能</p>
      <h2>轻量但不简陋</h2>
    </div>
    <div class="grid">
      {app.features.map(f => (
        <div class="cell reveal">
          <div class="cell-ico">{f.icon}</div>
          <h3>{f.title}</h3>
          <p>{f.desc}</p>
        </div>
      ))}
    </div>
  </div>
</section>

<section class="sec-darker" id="platforms">
  <div class="wrap">
    <div class="spot-head reveal">
      <p class="eyebrow">平台</p>
      <h2>专为 macOS 打造</h2>
    </div>
    <div class="plats" style="grid-template-columns:1fr">
      <div class="plat reveal" style="max-width:560px;margin:0 auto">
        <span class="plat-tag">macOS</span>
        <h3>菜单栏轻量工具</h3>
        <ul>
          <li>常驻菜单栏，不打扰日常使用</li>
          <li>支持 SMB / WebDAV / AFP / NFS 四种协议</li>
          <li>静默自动重连，无需用户介入</li>
          <li>中英双语，随系统语言自动切换</li>
        </ul>
      </div>
    </div>
  </div>
</section>

<section class="sec-light get" id="get">
  <div class="wrap">
    <div class="reveal">
      <p class="eyebrow">立即获取</p>
      <h2>下载智卷</h2>
      <p class="lead">GitHub 免费下载，MIT 开源。</p>
    </div>
    <div class="get-cards" style="grid-template-columns:1fr;max-width:320px;margin-left:auto;margin-right:auto">
      <div class="get-card reveal">
        <div class="store-ph">🐙</div>
        <h3>GitHub Releases</h3>
        <p>下载最新版 DMG，拖入 Applications 即可使用。当前版本 v{app.version}。</p>
        <a class="btn btn-primary" href={app.downloadUrl} target="_blank" rel="noopener">{app.downloadLabel}</a>
      </div>
    </div>
  </div>
</section>

<script>
(function(){
  var els = document.querySelectorAll('.reveal');
  if(!('IntersectionObserver' in window)){els.forEach(function(e){e.classList.add('in')});return;}
  var io = new IntersectionObserver(function(entries){
    entries.forEach(function(en){ if(en.isIntersecting){ en.target.classList.add('in'); io.unobserve(en.target); } });
  },{threshold:.15});
  els.forEach(function(e){io.observe(e)});
})();
</script>
</Base>
